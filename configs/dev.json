                "pictures_per_stop": 1,
                "hover_time_s": 1
            },
            "forward": {
                "optimize": true,
                "vertical": false,
                "one_way": false
            }
        },
        "approach": {
            "drop_method": "unguided",
            "drop_angle_rad": 2.52134317,
            "drop_altitude_m": 35.0,
            "guided_drop_distance_m": 50.0,
            "unguided_drop_distance_m": 50.0
        }
    },
    "cv": {
        "yolo_model_dir": "/workspaces/obcpp/models/yolo-wittner-v2.onnx",
        "detection_threshold": 0.1,
        "input_width": 1024,
        "input_height": 1024
    },
    "camera": {
