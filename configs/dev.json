{
    "logging": {
        "dir": "/workspaces/obcpp/logs"
    },
    "network": {
        "mavlink": {
            "connect": "tcp://localhost:14552",
            "log_params": false,
            "telem_poll_rate": 2.0
        },
        "gcs": {
            "port": 5010
        }
    },
    "takeoff": {
        "altitude_m": 30.0,
        "payload_size": 2
    },
    "pathing": {
        "laps": 2,
        "dubins": {
            "turning_radius": 30.0,
            "point_separation": 20.0
        },
        "rrt": {
            "iterations_per_waypoint": 512,
            "rewire_radius": 256.0,
